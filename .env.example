NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=x.y.z
NEXT_PUBLIC_UNSPLASH_SECRET_KEY=x.y.z
NEXT_PUBLIC_PEXELS_API_KEY=x.y.z
NEXT_PUBLIC_PIXABAY_API_KEY=x.y.z

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=x.y.z
NEXT_PUBLIC_SUPABASE_ANON_KEY=x.y.z

# Canonical origin used for OAuth redirects (e.g. https://app.example.com).
# Falls back to the request origin if unset, which is fine for Vercel but
# unsafe when deployed without a trusted reverse proxy.
NEXT_PUBLIC_SITE_URL=https://your-domain.example